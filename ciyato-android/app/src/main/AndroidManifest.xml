<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Required to read the list of installed apps for categorization -->
    <uses-permission android:name="android.permission.QUERY_ALL_PACKAGES" />

    <!-- Required for Open-Meteo weather API and Nominatim reverse-geocoding calls -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!--
        Foreground location only — requested at runtime, ONLY when user opens Weather
        and taps "Enable Local Weather". Never requested at onboarding. No background location.
    -->
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />

    <application
        android:name=".CiyatoApplication"
        android:allowBackup="false"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.Ciyato">

        <!--
            LauncherHomeActivity — the REAL launcher/home screen.
            Must have HOME + DEFAULT category so Android offers it as a Home app.
            singleTask ensures only one instance exists when Home is pressed.
        -->
        <activity
            android:name=".LauncherHomeActivity"
            android:exported="true"
            android:launchMode="singleTask"
            android:stateNotNeeded="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.HOME" />
                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>
        </activity>

        <!--
            MainActivity — opens when user taps the Ciyato icon from another launcher.
            Shows onboarding (first launch) or the internal dashboard.
        -->
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTop">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

    </application>

</manifest>
